#!/usr/bin/env python4
import os
import glob

def parse_and_transform(filename):
    base_name = os.path.splitext(os.path.basename(filename))[0]

    with open(filename, "r", encoding="utf-8") as f:
        lines = f.readlines()

    block_lines = []          # ? ???? ???? ??? ???
    header = None             # ['a', 'b', 'c', 'temper', ...]
    data_rows = []            # [['5','6',...], ['1','2',...], ...]
    after_title = False
    expecting_header = False

    for line in lines:
        stripped = line.strip()

        # 1) $DATA1, $OPTION ?: $? ???? ?? ??
        if stripped.startswith("$"):
            continue

        # 2) .TITLE ??
        if stripped.upper().startswith(".TITLE"):
            block_lines.append(f".TITLE '{base_name}'\n")
            after_title = True
            expecting_header = True
            continue

        # 3) TITLE ?? ? ?? ? -> ??
        if after_title and expecting_header:
            if not stripped:
                continue  # ?? ??? ?? ???
            header = stripped.split()
            expecting_header = False
            continue

        # 4) ?? ??? ?? ? -> ???
        if after_title and (header is not None):
            if not stripped:
                continue
            parts = stripped.split()
            data_rows.append(parts)

    # ??? ??? ??? TITLE? ?? ??? ??
    if header is None:
        return block_lines

    # ---- temper / temp ??? ? ??? ?? (?? + ? ??) ----

    if "temper" in header:
        tname = "temper"
    elif "temp" in header:
        tname = "temp"
    else:
        block_lines.append(" ".join(header) + "\n")
        for row in data_rows:
            block_lines.append(" ".join(row) + "\n")
        block_lines.append("\n")
        return block_lines

    tidx = header.index(tname)

    new_header = [header[tidx]] + header[:tidx] + header[tidx+1:]

    # ??? ???: ? row? ?? ????
    new_data_rows = []
    for row in data_rows:
        # row ??? header?? ??? ?? ?? ??? ??
        # (???? ?? ?? ??)
        if len(row) <= tidx:
            # temper ??? ?? ??? ??? ??
            new_data_rows.append(row)
            continue
        new_row = [row[tidx]] + row[:tidx] + row[tidx+1:]
        new_data_rows.append(new_row)

    block_lines.append(" ".join(new_header) + "\n")
    for row in new_data_rows:
        block_lines.append(" ".join(row) + "\n")
    block_lines.append("\n")  # ?? ?? ?? ? ? ???

    return block_lines


if __name__ == "__main__":
    curdir = os.getcwd()
    ma0_path = os.path.join(curdir, "meas_merge")
    output_file = os.path.join(curdir, "merged_meas.txt")
#    output_file = os.path.join(ma0_path, "meas_merged.txt")

    patterns = ["*.ma0", "*.mt0", "*.ms0", "*.mt"]

    merged_lines = []

    for pattern in patterns:
        for filepath in glob.glob(os.path.join(ma0_path, pattern)):
            block = parse_and_transform(filepath)
            merged_lines.extend(block)

    with open(output_file, "w", encoding="utf-8") as f:
        f.writelines(merged_lines)

    print(f"done: {output_file}")

